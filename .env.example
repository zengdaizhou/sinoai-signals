# ─── AI 生成 ───────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-key-here
OPENROUTER_API_KEY=sk-or-v1-xxx

# ─── Vercel 管理后台 ─────────────────────────────────────────
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
ADMIN_KEY=your-admin-password

# ─── Substack 发布（二选一）─────────────────────────────────
SUBSTACK_SID=s%3Ayour-connect-sid-cookie
# 或使用邮箱密码登录:
# SUBSTACK_EMAIL=you@example.com
# SUBSTACK_PASSWORD=your-password
SUBSTACK_URL=https://sinoaisignals.substack.com

# ─── Twitter/X 自动发文 ─────────────────────────────────────
TWITTER_APP_KEY=your-app-key
TWITTER_APP_SECRET=your-app-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_SECRET=your-access-secret

# ─── Telegram 通知 ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
